{
  "experimental": {
    "enableAgents": true
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "name": "gk-session-init",
            "type": "command",
            "command": "node ~/.gemini/hooks/session-init.cjs",
            "timeout": 5000,
            "description": "GeminiCLI adapter: session-init"
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "gk-dev-rules-reminder",
            "type": "command",
            "command": "node ~/.gemini/hooks/dev-rules-reminder.cjs",
            "timeout": 5000,
            "description": "GeminiCLI adapter: dev-rules-reminder"
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "write_file",
        "hooks": [
          {
            "name": "gk-descriptive-name",
            "type": "command",
            "command": "node ~/.gemini/hooks/descriptive-name.cjs",
            "timeout": 5000,
            "description": "GeminiCLI adapter: descriptive-name"
          }
        ]
      },
      {
        "matcher": "shell|glob|grep|read_file|edit|write_file",
        "hooks": [
          {
            "name": "gk-scout-block",
            "type": "command",
            "command": "node ~/.gemini/hooks/scout-block.cjs",
            "timeout": 5000,
            "description": "GeminiCLI adapter: scout-block"
          },
          {
            "name": "gk-privacy-block",
            "type": "command",
            "command": "node ~/.gemini/hooks/privacy-block.cjs",
            "timeout": 5000,
            "description": "GeminiCLI adapter: privacy-block"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "edit|write_file|multiedit",
        "hooks": [
          {
            "name": "gk-post-edit-simplify-reminder",
            "type": "command",
            "command": "node ~/.gemini/hooks/post-edit-simplify-reminder.cjs",
            "timeout": 5000,
            "description": "GeminiCLI adapter: post-edit-simplify-reminder"
          }
        ]
      }
    ]
  }
}